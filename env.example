APP_ENV=local
LOG_LEVEL=INFO

# Supabase
SUPABASE_URL=CHANGEME
SUPABASE_SERVICE_ROLE_KEY=CHANGEME
SUPABASE_DB_URL=CHANGEME
SUPABASE_MCP_URL=CHANGEME
SUPABASE_STORAGE_BUCKET_IDENTITIES=vb-identities-local
SUPABASE_STORAGE_BUCKET_CONTENT=vb-content-local
SUPABASE_STORAGE_BUCKET_MODELS=vb-models-local
SUPABASE_STORAGE_BUCKET_DATASETS=vb-datasets-local
# S3-compatible
AWS_ACCESS_KEY_ID=CHANGEME
AWS_SECRET_ACCESS_KEY=CHANGEME
AWS_REGION=us-east-1
S3_BUCKET_IDENTITIES=vb-identities-local
S3_BUCKET_CONTENT=vb-content-local
S3_BUCKET_MODELS=vb-models-local
S3_BUCKET_DATASETS=vb-datasets-local

# GPU providers
MODAL_TOKEN_ID=CHANGEME
MODAL_TOKEN_SECRET=CHANGEME
BEAM_API_KEY=CHANGEME
RUNPOD_API_KEY=CHANGEME

# Visual pipeline
VISUAL_EXECUTION_PROVIDER=routed
S1_IMAGE_PROVIDER=modal
S1_LORA_TRAIN_PROVIDER=modal
S1_LLM_PROVIDER=openai
S2_IMAGE_PROVIDER=modal
S2_VIDEO_PROVIDER=modal
COMFYUI_BASE_URL=http://localhost:8188
COMFYUI_WORKFLOW_IMAGE_ID=CHANGEME
COMFYUI_WORKFLOW_IMAGE_VERSION=v1
# workflow principal del runtime `S1 image`
COMFYUI_WORKFLOW_IDENTITY_ID=CHANGEME
COMFYUI_WORKFLOW_IDENTITY_VERSION=v1
COMFYUI_WORKFLOW_CONTENT_ID=CHANGEME
COMFYUI_WORKFLOW_CONTENT_VERSION=v1
COMFYUI_WORKFLOW_VIDEO_ID=CHANGEME
COMFYUI_WORKFLOW_VIDEO_VERSION=v1
COMFYUI_IP_ADAPTER_MODEL=plus_face
COMFYUI_IP_ADAPTER_NODE_ID=CHANGEME
COMFYUI_FACE_DETECTOR_NODE_ID=CHANGEME
COMFYUI_FACE_DETAILER_NODE_ID=CHANGEME
COMFYUI_FACE_CONFIDENCE_THRESHOLD=0.8
COMFYUI_RESUME_CACHE_MODE=checkpoint
COMFYUI_HTTP_TIMEOUT_SECONDS=30
PROVIDER_HTTP_TIMEOUT_SECONDS=30
PROVIDER_POLL_INTERVAL_SECONDS=3
PROVIDER_JOB_TIMEOUT_SECONDS=900
COMFYUI_FLUX_DIFFUSION_MODEL_NAME=flux1-schnell.safetensors
COMFYUI_FLUX_AE_NAME=ae.safetensors
COMFYUI_FLUX_CLIP_L_NAME=clip_l.safetensors
COMFYUI_FLUX_T5XXL_NAME=t5xxl_fp8_e4m3fn.safetensors
MODEL_CACHE_ROOT=CHANGEME
MODEL_CACHE_FLUX_DIFFUSION_PATH=CHANGEME
MODEL_CACHE_FLUX_AE_PATH=CHANGEME
MODEL_CACHE_FLUX_CLIP_L_PATH=CHANGEME
MODEL_CACHE_FLUX_T5XXL_PATH=CHANGEME
MODEL_CACHE_IPADAPTER_FLUX_PATH=CHANGEME
MODEL_BOOTSTRAP_WAIT_SECONDS=45
FLUX_DIFFUSION_MODEL_URL=CHANGEME
FLUX_AE_URL=CHANGEME
FLUX_CLIP_L_URL=CHANGEME
FLUX_T5XXL_URL=CHANGEME
IPADAPTER_FLUX_URL=CHANGEME
# contrato principal de Modal: app y function
S1_IMAGE_EXECUTION_BACKEND=modal
# para `S1 Image` los defaults del repo ya apuntan a `vixenbliss-s1-image`
# con `MODAL_TOKEN_ID` y `MODAL_TOKEN_SECRET` alcanza para ejecutar pruebas reales
S1_IMAGE_MODAL_APP_NAME=vixenbliss-s1-image
S1_IMAGE_MODAL_FUNCTION_NAME=run_s1_image_job
S1_IMAGE_MODAL_HEALTHCHECK_FUNCTION_NAME=runtime_healthcheck
S1_LORA_TRAIN_MODAL_APP_NAME=vixenbliss-s1-lora-train
S1_LORA_TRAIN_MODAL_WEB_FUNCTION_NAME=fastapi_app
S1_LLM_MODAL_APP_NAME=vixenbliss-s1-llm-gpt41mini
S1_LLM_MODAL_WEB_FUNCTION_NAME=fastapi_app
# fallback legado solo si aparece un proxy HTTP intermedio; no es necesario para `S1 Image`
MODAL_ENDPOINT_S1_IMAGE=CHANGEME
MODAL_ENDPOINT_S1_LORA_TRAIN=CHANGEME
MODAL_ENDPOINT_S1_LLM=CHANGEME
MODAL_ENDPOINT_S2_IMAGE=CHANGEME
MODAL_ENDPOINT_S2_VIDEO=CHANGEME

# Optional future Beam endpoints
BEAM_ENDPOINT_S1_IMAGE=CHANGEME
BEAM_ENDPOINT_S1_LORA_TRAIN=CHANGEME
BEAM_ENDPOINT_S1_LLM=CHANGEME
BEAM_ENDPOINT_S2_IMAGE=CHANGEME
BEAM_ENDPOINT_S2_VIDEO=CHANGEME

# Legacy Runpod reference
RUNPOD_ENDPOINT_IMAGE_IDENTITY=CHANGEME
RUNPOD_ENDPOINT_IMAGE_CONTENT=CHANGEME
RUNPOD_ENDPOINT_IMAGE_GEN=CHANGEME
RUNPOD_ENDPOINT_LORA_TRAIN=CHANGEME
RUNPOD_ENDPOINT_VIDEO_GEN=CHANGEME
RUNPOD_POLL_INTERVAL_SECONDS=3
RUNPOD_JOB_TIMEOUT_SECONDS=600
RUNPOD_USE_RUNSYNC=false
BASE_IMAGE_MODEL_ID=CHANGEME
BASE_VIDEO_MODEL_ID=CHANGEME
LORA_TRAINER_PROVIDER=modal
FLUXSCHNELL_ENDPOINT=CHANGEME

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=CHANGEME
OTEL_SERVICE_NAME=vixenbliss-creator
LANGFUSE_PUBLIC_KEY=CHANGEME
LANGFUSE_SECRET_KEY=CHANGEME

# LLM
LLAMA_CPP_BASE_URL=http://localhost:8080
S1_LLM_BACKEND=openai
S1_LLM_RUNTIME_BASE_URL=CHANGEME
S1_LLM_RUNTIME_API_KEY=CHANGEME
S1_LLM_RUNTIME_MODEL=gpt-4.1-mini
S1_LLM_RUNTIME_TIMEOUT_SECONDS=120
# LangGraph remains the orchestrator; `S1 llm` only prepares generation manifests
OPEN_AI_TOKEN=CHANGEME
OPENAI_API_KEY=CHANGEME
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_SERVERLESS_BASE_URL=CHANGEME
LLM_SERVERLESS_API_KEY=CHANGEME
LLM_SERVERLESS_MODEL=CHANGEME
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=120
COMFYUI_COPILOT_BASE_URL=CHANGEME
COMFYUI_COPILOT_API_KEY=CHANGEME
COMFYUI_COPILOT_PATH=/recommend
AGENTIC_BRAIN_MAX_ATTEMPTS=2
AGENTIC_BRAIN_SOURCE_ISSUE_ID=DEV-7
AGENTIC_BRAIN_SOURCE_EPIC_ID=DEV-3
AGENTIC_BRAIN_CONTRACT_OWNER=Codex

# Ops
DEFAULT_JOB_TIMEOUT_SECONDS=900
DEFAULT_JOB_MAX_RETRIES=2

# Tooling and integrations
YOUTRACK_BASE_URL=CHANGEME
YOUTRACK_API_TOKEN=CHANGEME
GITHUB_TOKEN=CHANGEME

# Directus S1 control plane
# API HTTP de Directus usada por el codigo del repo.
# Debe ser la base de la instancia, sin sufijo `/mcp`.
DIRECTUS_BASE_URL=http://directus-pggc4wo0s0wc4scw0wc80scc.76.13.170.240.sslip.io
# MCP remoto de Directus usado por agentes y tooling.
# Debe apuntar a la misma instancia, pero terminando en `/mcp`.
DIRECTUS_MCP_URL=http://directus-pggc4wo0s0wc4scw0wc80scc.76.13.170.240.sslip.io/mcp
DIRECTUS_API_TOKEN=CHANGEME
DIRECTUS_TIMEOUT_SECONDS=30
DIRECTUS_WEBHOOK_SECRET=CHANGEME
# storage target usado por `S1 image` para persistir solamente imagenes como `base_image`
DIRECTUS_ASSETS_STORAGE=directus
S1_CONTROL_BIND_HOST=127.0.0.1
S1_CONTROL_PORT=8091
S1_CONTROL_PUBLIC_BASE_URL=CHANGEME
