{
  "mcpServers": {
    "youtrack": {
      "transport": "stdio",
      "command": "CHANGEME_MCP_COMMAND",
      "args": [
        "CHANGEME_ARG_1"
      ],
      "env": {
        "YOUTRACK_BASE_URL": "${YOUTRACK_BASE_URL}",
        "YOUTRACK_API_TOKEN": "${YOUTRACK_API_TOKEN}"
      }
    },
    "supabase": {
      "transport": "http",
      "url": "${SUPABASE_MCP_URL}"
    },
    "github": {
      "transport": "stdio",
      "command": "CHANGEME_MCP_COMMAND",
      "args": [
        "CHANGEME_ARG_1"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "runpod": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@runpod/mcp-server@latest"
      ],
      "env": {
        "RUNPOD_API_KEY": "${RUNPOD_API_KEY}"
      }
    }
  }
}
