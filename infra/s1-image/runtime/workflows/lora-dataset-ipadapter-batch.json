{
  "workflow_id": "lora-dataset-ipadapter-batch",
  "workflow_version": "2026-04-08",
  "description": "FLUX.1-schnell workflow approved for System 1 LoRA dataset generation with IPAdapter Flux and deterministic shot-plan batching.",
  "vb_meta": {
    "workflow_id": "lora-dataset-ipadapter-batch",
    "workflow_version": "2026-04-08",
    "model_family": "flux",
    "workflow_family": "flux_lora_dataset_reference",
    "logical_nodes": {
      "ip_adapter": "ip_adapter_apply",
      "face_detector": "face_detector",
      "face_detailer": "face_detailer"
    }
  },
  "load_diffusion_model": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "flux1-schnell.safetensors",
      "weight_dtype": "default"
    }
  },
  "model_sampling_flux": {
    "class_type": "ModelSamplingFlux",
    "inputs": {
      "model": [
        "load_diffusion_model",
        0
      ],
      "max_shift": 1.15,
      "base_shift": 0.5,
      "width": 1024,
      "height": 1024
    }
  },
  "load_dual_clip": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "clip_l.safetensors",
      "clip_name2": "t5xxl_fp8_e4m3fn.safetensors",
      "type": "flux"
    }
  },
  "load_ae": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    }
  },
  "positive_prompt": {
    "class_type": "CLIPTextEncodeFlux",
    "inputs": {
      "clip": [
        "load_dual_clip",
        0
      ],
      "clip_l": "CHANGEME_POSITIVE_PROMPT",
      "t5xxl": "CHANGEME_POSITIVE_PROMPT",
      "guidance": 3.5
    }
  },
  "negative_prompt": {
    "class_type": "CLIPTextEncodeFlux",
    "inputs": {
      "clip": [
        "load_dual_clip",
        0
      ],
      "clip_l": "CHANGEME_NEGATIVE_PROMPT",
      "t5xxl": "CHANGEME_NEGATIVE_PROMPT",
      "guidance": 3.5
    }
  },
  "empty_latent": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    }
  },
  "random_noise": {
    "class_type": "RandomNoise",
    "inputs": {
      "noise_seed": 42
    }
  },
  "ksampler_select": {
    "class_type": "KSamplerSelect",
    "inputs": {
      "sampler_name": "euler"
    }
  },
  "sampler_scheduler": {
    "class_type": "BasicScheduler",
    "inputs": {
      "model": [
        "ip_adapter_apply",
        0
      ],
      "scheduler": "simple",
      "steps": 12,
      "denoise": 1.0
    }
  },
  "basic_guider": {
    "class_type": "BasicGuider",
    "inputs": {
      "model": [
        "ip_adapter_apply",
        0
      ],
      "conditioning": [
        "positive_prompt",
        0
      ]
    }
  },
  "load_reference_image": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "CHANGEME_REFERENCE_IMAGE.png"
    }
  },
  "load_ip_adapter_model": {
    "class_type": "IPAdapterFluxLoader",
    "inputs": {
      "ipadapter": "ip-adapter.bin",
      "clip_vision": "google/siglip-so400m-patch14-384",
      "provider": "cuda"
    }
  },
  "ip_adapter_apply": {
    "class_type": "ApplyIPAdapterFlux",
    "inputs": {
      "model": [
        "model_sampling_flux",
        0
      ],
      "ipadapter_flux": [
        "load_ip_adapter_model",
        0
      ],
      "image": [
        "load_reference_image",
        0
      ],
      "weight": 0.85,
      "start_percent": 0.0,
      "end_percent": 0.95
    }
  },
  "sampler_custom_advanced": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise": [
        "random_noise",
        0
      ],
      "guider": [
        "basic_guider",
        0
      ],
      "sampler": [
        "ksampler_select",
        0
      ],
      "sigmas": [
        "sampler_scheduler",
        0
      ],
      "latent_image": [
        "empty_latent",
        0
      ]
    }
  },
  "vae_decode": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": [
        "sampler_custom_advanced",
        0
      ],
      "vae": [
        "load_ae",
        0
      ]
    }
  },
  "face_detector": {
    "class_type": "UltralyticsDetectorProvider",
    "inputs": {
      "model_name": "bbox/face_yolov8m.pt"
    }
  },
  "face_detailer": {
    "class_type": "FaceDetailer",
    "inputs": {
      "image": [
        "vae_decode",
        0
      ],
      "model": [
        "ip_adapter_apply",
        0
      ],
      "clip": [
        "load_dual_clip",
        0
      ],
      "vae": [
        "load_ae",
        0
      ],
      "positive": [
        "positive_prompt",
        0
      ],
      "negative": [
        "negative_prompt",
        0
      ],
      "bbox_detector": [
        "face_detector",
        0
      ],
      "guide_size": 1024,
      "guide_size_for": true,
      "max_size": 1024,
      "seed": 42,
      "steps": 12,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 0.35,
      "feather": 12,
      "noise_mask": true,
      "force_inpaint": true,
      "bbox_threshold": 0.8
    }
  },
  "save_base_image": {
    "class_type": "SaveImage",
    "inputs": {
      "images": [
        "vae_decode",
        0
      ],
      "filename_prefix": "vb/base"
    }
  },
  "save_final_image": {
    "class_type": "SaveImage",
    "inputs": {
      "images": [
        "face_detailer",
        0
      ],
      "filename_prefix": "vb/final"
    }
  }
}
