# Runpod
RUNPOD_API_KEY=CHANGEME
RUNPOD_ENDPOINT_IMAGE_GEN=CHANGEME
RUNPOD_POLL_INTERVAL_SECONDS=3
RUNPOD_JOB_TIMEOUT_SECONDS=600
RUNPOD_USE_RUNSYNC=false

# ComfyUI runtime
COMFYUI_BASE_URL=http://localhost:8188
COMFYUI_PUBLIC_BASE_URL=
COMFYUI_PORT=8188
COMFYUI_LISTEN=0.0.0.0
COMFYUI_HOME=/opt/comfyui
COMFYUI_CUSTOM_NODES_DIR=/opt/comfyui/custom_nodes
COMFYUI_MODELS_DIR=/opt/comfyui/models
COMFYUI_USER_DIR=/opt/comfyui/user/default
COMFYUI_INPUT_DIR=/opt/comfyui/input

# Workflow contract
COMFYUI_WORKFLOW_IMAGE_ID=base-image-ipadapter-impact
COMFYUI_WORKFLOW_IMAGE_VERSION=2026-03-30
COMFYUI_BASE_CHECKPOINT_NAME=base-image-model.safetensors
COMFYUI_IP_ADAPTER_MODEL=plus_face
COMFYUI_IP_ADAPTER_NODE_ID=ip_adapter_apply
COMFYUI_FACE_DETECTOR_NODE_ID=face_detector
COMFYUI_FACE_DETAILER_NODE_ID=face_detailer
COMFYUI_FACE_CONFIDENCE_THRESHOLD=0.8

# Optional model bootstrap
IPADAPTER_PLUS_FACE_URL=CHANGEME
CHECKPOINT_MODEL_URL=CHANGEME
VAE_MODEL_URL=
